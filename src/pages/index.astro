---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const posterModules = import.meta.glob('../assets/p*.*', { eager: true, import: 'default' });
const posters = Object.entries(posterModules)
	.map(([path, mod]) => {
		const match = path.match(/[\\/]p(\d+)\./i);
		const src =
			typeof mod === 'string'
				? mod
				: typeof (mod as { src?: unknown }).src === 'string'
					? ((mod as { src: string }).src)
					: typeof (mod as { default?: unknown }).default === 'string'
						? ((mod as { default: string }).default)
						: typeof ((mod as { default?: { src?: unknown } }).default?.src) === 'string'
							? ((mod as { default: { src: string } }).default.src)
							: '';
		return {
			sortOrder: match ? Number(match[1]) : Number.MAX_SAFE_INTEGER,
			title: `Poster ${match ? match[1] : ''}`.trim(),
			src,
		};
	})
	.filter((poster) => poster.src)
		.sort((a, b) => b.sortOrder - a.sortOrder);

const loopPosters = [...posters, ...posters];
const posterStep = 300;
const loopDistance = posters.length * posterStep;
const loopDuration = Math.max(12, posters.length * 3);
const backgroundImages = posters.map((poster) => poster.src);
---

<Layout>
	<Header />
	<main class="landing-page">
		<div class="bg-image-layer" aria-hidden="true">
			<img
				id="random-bg-image"
				src={backgroundImages[0] ?? ''}
				alt=""
				loading="eager"
				decoding="async"
			/>
		</div>
		<div class="bg-dim-overlay" aria-hidden="true"></div>

		<section class="hero-panel" id="home">
			<div class="hero-card">
				<div class="video-player">
					<iframe
						id="home-vimeo-player"
						src="https://player.vimeo.com/video/925707755?api=1&player_id=home-vimeo-player"
						title="VFX demo reel"
						frameborder="0"
						allow="autoplay; fullscreen; picture-in-picture"
						allowfullscreen
					></iframe>
				</div>
			</div>
		</section>

		<section
			class="poster-carousel"
			aria-label="Movie posters carousel"
			style={`--loop-distance: ${loopDistance}px; --carousel-duration: ${loopDuration}s;`}
		>
			<div class="carousel-track">
				{loopPosters.map((poster) => (
					<article class="poster-card">
						<img class="poster-image" src={poster.src} alt="Movie poster" loading="lazy" />
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>

<script src="https://player.vimeo.com/api/player.js"></script>
<script define:vars={{ backgroundImages }}>
	const initDynamicBackground = () => {
		const bgImage = document.getElementById('random-bg-image');

		if (!(bgImage instanceof HTMLImageElement) || !Array.isArray(backgroundImages) || backgroundImages.length === 0) {
			return;
		}

		const randomIndex = Math.floor(Math.random() * backgroundImages.length);
		bgImage.src = backgroundImages[randomIndex];

		const maxShift = 26;
		const scale = 1.12;
		let ticking = false;

		const updateParallax = () => {
			const shift = Math.max(-maxShift, Math.min(maxShift, window.scrollY * 0.12));
			bgImage.style.transform = `translate3d(0, ${shift.toFixed(2)}px, 0) scale(${scale})`;
			ticking = false;
		};

		const onScroll = () => {
			if (ticking) {
				return;
			}

			ticking = true;
			window.requestAnimationFrame(updateParallax);
		};

		if (bgImage.dataset.parallaxBound !== 'true') {
			window.addEventListener('scroll', onScroll, { passive: true });
			bgImage.dataset.parallaxBound = 'true';
		}
		updateParallax();
	};

	const setVideoPlayingState = (isPlaying) => {
		const carousel = document.querySelector('.poster-carousel');
		const carouselTrack = document.querySelector('.carousel-track');

		if (!(carousel instanceof HTMLElement) || !(carouselTrack instanceof HTMLElement)) {
			return;
		}

		carousel.classList.toggle('is-video-playing', isPlaying);
		carouselTrack.style.animationPlayState = isPlaying ? 'paused' : 'running';
	};

	const initVideoAwareCarousel = () => {
		const iframe = document.getElementById('home-vimeo-player');

		if (!(iframe instanceof HTMLIFrameElement) || iframe.dataset.videoSyncBound === 'true') {
			return;
		}

		const playerOrigin = 'https://player.vimeo.com';

		const sendVimeoCommand = (command) => {
			iframe.contentWindow?.postMessage(JSON.stringify(command), playerOrigin);
		};

		const onMessage = (event) => {
			if (event.origin !== playerOrigin) {
				return;
			}

			let eventData = event.data;
			if (typeof event.data === 'string') {
				try {
					eventData = JSON.parse(event.data);
				} catch {
					return;
				}
			}

			if (!eventData || typeof eventData !== 'object' || eventData.player_id !== 'home-vimeo-player') {
				return;
			}

			if (eventData.event === 'play') {
				setVideoPlayingState(true);
			}

			if (eventData.event === 'pause' || eventData.event === 'ended') {
				setVideoPlayingState(false);
			}
		};

		const bindVimeoEvents = () => {
			sendVimeoCommand({ method: 'addEventListener', value: 'play' });
			sendVimeoCommand({ method: 'addEventListener', value: 'pause' });
			sendVimeoCommand({ method: 'addEventListener', value: 'ended' });
		};

		window.addEventListener('message', onMessage);
		iframe.addEventListener('load', bindVimeoEvents, { once: true });
		if (iframe.contentWindow) {
			bindVimeoEvents();
		}
		iframe.dataset.videoSyncBound = 'true';
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => {
			initDynamicBackground();
			initVideoAwareCarousel();
		}, { once: true });
	} else {
		initDynamicBackground();
		initVideoAwareCarousel();
	}

	document.addEventListener('astro:page-load', initDynamicBackground);
	document.addEventListener('astro:page-load', initVideoAwareCarousel);
</script>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		font-family: Inter, system-ui, sans-serif;
		background: #020617;
		color: #0f172a;
	}

	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
		isolation: isolate;
	}

	.bg-image-layer,
	.bg-dim-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.bg-image-layer {
		z-index: 0;
		overflow: hidden;
	}

	.bg-image-layer img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		transform: translate3d(0, 0, 0) scale(1.12);
		transition: transform 120ms linear;
		will-change: transform;
	}

	.bg-dim-overlay {
		z-index: 1;
		background: linear-gradient(to bottom, rgba(2, 6, 23, 0.52), rgba(2, 6, 23, 0.68));
	}

	.hero-panel,
	.poster-carousel {
		position: relative;
		z-index: 2;
	}

	.hero-panel {
		flex: 0.5;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 80px 24px 48px;
	}

	.hero-card {
		width: min(1120px, 100%);
		padding: 24px;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 32px;
		background: #ffffff;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		gap: 32px;
	}


	.video-player {
		width: 100%;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
	}

	.poster-carousel {
		width: 100vw;
		margin: 36px calc(50% - 50vw) 0;
		padding: 0 24px;
		overflow: hidden;
		filter: brightness(1);
		transition: filter 180ms ease;
	}

	.poster-carousel.is-video-playing {
		filter: brightness(0.6);
	}

	.carousel-track {
		display: flex;
		width: auto;
		animation: carousel var(--carousel-duration, 16s) linear infinite;
		gap: 20px;
		transform: translateX(0);
	}

	.poster-card {
		flex: 0 0 280px;
		width: 280px;
		height: 380px;
		position: relative;
		border-radius: 0;
		overflow: hidden;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.poster-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@keyframes carousel {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(calc(-1 * var(--loop-distance, 1180px)));
		}
	}

	.video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	@media (max-width: 860px) {
		.page-header {
			flex-wrap: wrap;
			gap: 20px;
		}

		.nav-menu {
			flex-wrap: wrap;
			justify-content: center;
			gap: 18px;
		}
	}

	@media (max-width: 580px) {
		.page-header {
			padding: 20px 18px;
		}

		.hero-panel {
			padding: 0 16px 32px;
		}
	}
</style>
