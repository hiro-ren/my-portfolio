---
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate icon" href="/Hlogo.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Hiro Ren Demo Reel</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100vh;
		background: #edf6ff;
		color: #0f172a;
	}

	body {
		position: relative;
		isolation: isolate;
		overflow-y: auto;
		overflow-x: clip;
		font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		background: transparent;
	}

	body::before {
		content: '';
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background:
			radial-gradient(900px 480px at -10% -15%, rgba(147, 197, 253, 0.42), transparent 62%),
			radial-gradient(760px 420px at 110% 0%, rgba(196, 181, 253, 0.34), transparent 60%),
			linear-gradient(135deg, #ffffff 0%, #ecf5ff 38%, #f4f8ff 68%, #edf6ff 100%);
	}

	:global(grammarly-desktop-integration),
	:global(grammarly-extension),
	:global([data-new-gr-c-s-check-loaded]),
	:global([data-gr-ext-installed]) {
		background: transparent !important;
	}

	main {
		min-height: 100vh;
	}

	.page-shell {
		min-height: calc(100vh - 96px);
		padding: 40px 32px;
		background: rgba(255, 255, 255, 0.58);
	}
</style>
