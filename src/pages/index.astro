---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const posterModules = import.meta.glob('../assets/p*.*', { eager: true, import: 'default' });
const posters = Object.entries(posterModules)
	.map(([path, mod]) => {
		const match = path.match(/[\\/]p(\d+)\./i);
		const src =
			typeof mod === 'string'
				? mod
				: typeof (mod as { src?: unknown }).src === 'string'
					? ((mod as { src: string }).src)
					: typeof (mod as { default?: unknown }).default === 'string'
						? ((mod as { default: string }).default)
						: typeof ((mod as { default?: { src?: unknown } }).default?.src) === 'string'
							? ((mod as { default: { src: string } }).default.src)
							: '';
		return {
			sortOrder: match ? Number(match[1]) : Number.MAX_SAFE_INTEGER,
			title: `Poster ${match ? match[1] : ''}`.trim(),
			src,
		};
	})
	.filter((poster) => poster.src)
	.sort((a, b) => a.sortOrder - b.sortOrder);

const loopPosters = [...posters, ...posters];
const posterStep = 300;
const loopDistance = posters.length * posterStep;
const loopDuration = Math.max(12, posters.length * 3);
---

<Layout>
	<Header />
	<main class="landing-page">

		<section class="hero-panel" id="home">
			<div class="hero-card">
				<div class="video-player">
					<iframe
						src="https://player.vimeo.com/video/925707755"
						title="VFX demo reel"
						frameborder="0"
						allow="autoplay; fullscreen; picture-in-picture"
						allowfullscreen
					></iframe>
				</div>
			</div>
		</section>

		<section
			class="poster-carousel"
			aria-label="Movie posters carousel"
			style={`--loop-distance: ${loopDistance}px; --carousel-duration: ${loopDuration}s;`}
		>
			<div class="carousel-track">
				{loopPosters.map((poster) => (
					<article class="poster-card">
						<img class="poster-image" src={poster.src} alt="Movie poster" loading="lazy" />
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		font-family: Inter, system-ui, sans-serif;
		background:
			radial-gradient(900px 480px at -10% -15%, rgba(147, 197, 253, 0.42), transparent 62%),
			radial-gradient(760px 420px at 110% 0%, rgba(191, 219, 254, 0.34), transparent 60%),
			radial-gradient(1100px 500px at 50% 120%, rgba(186, 230, 253, 0.28), transparent 60%),
			linear-gradient(135deg, #ffffff 0%, #ecf5ff 40%, #f4f8ff 70%, #edf6ff 100%);
		background-repeat: no-repeat;
		background-attachment: fixed;
		color: #0f172a;
	}

	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}


	.hero-panel {
		flex: 0.5;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 80px 24px 48px;
	}

	.hero-card {
		width: min(1120px, 100%);
		padding: 24px;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 32px;
		background: #ffffff;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		gap: 32px;
	}


	.video-player {
		width: 100%;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
	}

	.poster-carousel {
		width: 100vw;
		margin: 36px calc(50% - 50vw) 0;
		padding: 0 24px;
		overflow: hidden;
	}

	.carousel-track {
		display: flex;
		width: auto;
		animation: carousel var(--carousel-duration, 16s) linear infinite;
		gap: 20px;
		transform: translateX(0);
	}

	.poster-card {
		flex: 0 0 280px;
		width: 280px;
		height: 380px;
		position: relative;
		border-radius: 28px;
		overflow: hidden;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.poster-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@keyframes carousel {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(calc(-1 * var(--loop-distance, 1180px)));
		}
	}

	.video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	@media (max-width: 860px) {
		.page-header {
			flex-wrap: wrap;
			gap: 20px;
		}

		.nav-menu {
			flex-wrap: wrap;
			justify-content: center;
			gap: 18px;
		}
	}

	@media (max-width: 580px) {
		.page-header {
			padding: 20px 18px;
		}

		.hero-panel {
			padding: 0 16px 32px;
		}
	}
</style>
