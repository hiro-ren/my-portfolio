---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout>
	<Header />
	<main class="landing-page">

		<section class="hero-panel" id="home">
			<div class="hero-card">
				<div class="video-player">
					<iframe
						src="https://player.vimeo.com/video/925707755"
						title="VFX demo reel"
						frameborder="0"
						allow="autoplay; fullscreen; picture-in-picture"
						allowfullscreen
					></iframe>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		font-family: Inter, system-ui, sans-serif;
		background: #f8fafc;
		color: #0f172a;
	}

	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}


	.hero-panel {
		flex: 0.5;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 24px 48px;
	}

	.hero-card {
		width: min(1120px, 100%);
		padding: 24px;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 32px;
		background: #ffffff;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.video-player {
		width: 100%;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
	}

	.video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	@media (max-width: 860px) {
		.page-header {
			flex-wrap: wrap;
			gap: 20px;
		}

		.nav-menu {
			flex-wrap: wrap;
			justify-content: center;
			gap: 18px;
		}
	}

	@media (max-width: 580px) {
		.page-header {
			padding: 20px 18px;
		}

		.hero-panel {
			padding: 0 16px 32px;
		}
	}
</style>
