---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const posterModules = import.meta.glob('../assets/p*.*', { eager: true, import: 'default' });
const posters = Object.entries(posterModules)
	.map(([path, mod]) => {
		const match = path.match(/[\\/]p(\d+)\./i);
		const src =
			typeof mod === 'string'
				? mod
				: typeof (mod as { src?: unknown }).src === 'string'
					? ((mod as { src: string }).src)
					: typeof (mod as { default?: unknown }).default === 'string'
						? ((mod as { default: string }).default)
						: typeof ((mod as { default?: { src?: unknown } }).default?.src) === 'string'
							? ((mod as { default: { src: string } }).default.src)
							: '';
		return {
			src,
		};
	})
	.filter((poster) => poster.src);

const backgroundImages = posters.map((poster) => poster.src);
---

<Layout>
	<Header />
	<main class="landing-page">
		<script is:inline>
			try {
				const initialBg =
					sessionStorage.getItem('portfolio-painted-bg-image') ??
					sessionStorage.getItem('portfolio-bg-image');
				if (initialBg) {
					document.documentElement.style.setProperty('--initial-bg-image', `url("${initialBg}")`);
				}
			} catch {
				// Ignore storage access errors.
			}
		</script>
		<div
			class="bg-image-layer"
			aria-hidden="true"
			style={`--default-bg-image: url('${backgroundImages[0] ?? ''}')`}
		>
			<div class="bg-frame bg-frame-a"></div>
			<div class="bg-frame bg-frame-b"></div>
		</div>
		<div class="bg-dim-overlay" aria-hidden="true"></div>

		<section class="hero-panel" id="projects-video">
			<div class="video-player">
				<iframe
					src="https://www.youtube.com/embed/gB90me0aqSY"
					title="YouTube demo reel"
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>
		</section>

		<section class="video-grid" id="projects-grid">
			<div class="grid-card">
				<div class="grid-video-item">
					<div class="grid-video-player">
						<iframe
							src="https://player.vimeo.com/video/251238799"
							title="VFX demo reel"
							frameborder="0"
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-description">
						<div class="video-description-title">Pixar Undergraduate Program</div>
						<div class="video-description-copy">Responsible for modelling, particle effects, additional lighting.</div>
					</div>
				</div>
				<div class="grid-video-item">
					<div class="grid-video-player">
						<iframe
							src="https://player.vimeo.com/video/197258267"
							title="VFX demo reel"
							frameborder="0"
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-description">
						<div class="video-description-title">BIRDCAGE - Short Film</div>
						<div class="video-description-copy">Responsible for Lighting, Shading, and compositing.
Vincent Cappelluti animation film ▷ http://www.vincentcapp.com/.</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script define:vars={{ backgroundImages }}>
	const initDynamicBackground = () => {
		const bgLayer = document.querySelector('.bg-image-layer');
		const bgFrameA = bgLayer?.querySelector('.bg-frame-a');
		const bgFrameB = bgLayer?.querySelector('.bg-frame-b');
		const bgStorageKey = 'portfolio-bg-image';
		const paintedBgKey = 'portfolio-painted-bg-image';

		if (
			!(bgLayer instanceof HTMLElement) ||
			!(bgFrameA instanceof HTMLElement) ||
			!(bgFrameB instanceof HTMLElement) ||
			!Array.isArray(backgroundImages) ||
			backgroundImages.length === 0
		) {
			return;
		}

		const navEntry = performance.getEntriesByType('navigation')[0];
		const navType = navEntry && typeof navEntry === 'object' && 'type' in navEntry ? navEntry.type : '';

		let sharedBgImage = sessionStorage.getItem(bgStorageKey);
		if (!sharedBgImage) {
			const randomIndex = Math.floor(Math.random() * backgroundImages.length);
			sharedBgImage = backgroundImages[randomIndex];
			sessionStorage.setItem(bgStorageKey, sharedBgImage);
		}

		const paintedBgImage = sessionStorage.getItem(paintedBgKey);
		const shouldUseFallback = !bgLayer.classList.contains('has-live-image');
		const activeIsB = bgLayer.classList.contains('is-b-active');
		const activeFrame = activeIsB ? bgFrameB : bgFrameA;
		const inactiveFrame = activeIsB ? bgFrameA : bgFrameB;
		let activeBgUrl = activeFrame.dataset.bgUrl ?? '';

		const setFrameImage = (frame, imageUrl) => {
			frame.style.backgroundImage = `url("${imageUrl}")`;
			frame.dataset.bgUrl = imageUrl;
		};

		const revealBackground = () => {
			if (shouldUseFallback) {
				bgLayer.classList.add('has-live-image');
			}
			document.documentElement.style.setProperty('--initial-bg-image', `url("${sharedBgImage}")`);
			sessionStorage.setItem(paintedBgKey, sharedBgImage);
		};

		const preloadImage = (imageUrl, onReady) => {
			const preload = new Image();
			preload.src = imageUrl;
			if (typeof preload.decode === 'function') {
				preload.decode().catch(() => undefined).finally(onReady);
				return;
			}
			preload.onload = onReady;
			preload.onerror = onReady;
		};

		if (!activeBgUrl) {
			const seedImage = paintedBgImage || sharedBgImage;
			setFrameImage(activeFrame, seedImage);
			activeBgUrl = seedImage;
		}

		if (activeBgUrl !== sharedBgImage) {
			preloadImage(sharedBgImage, () => {
				setFrameImage(inactiveFrame, sharedBgImage);
				bgLayer.classList.toggle('is-b-active', !activeIsB);
				revealBackground();
			});
		} else {
			setFrameImage(activeFrame, sharedBgImage);
			revealBackground();
		}

		const maxShift = 26;
		const scale = 1.12;
		let ticking = false;

		const updateParallax = () => {
			const shift = Math.max(-maxShift, Math.min(maxShift, window.scrollY * 0.12));
			bgLayer.style.setProperty('--bg-shift', `${shift.toFixed(2)}px`);
			bgLayer.style.setProperty('--bg-scale', `${scale}`);
			ticking = false;
		};

		const onScroll = () => {
			if (ticking) {
				return;
			}

			ticking = true;
			window.requestAnimationFrame(updateParallax);
		};

		if (bgLayer.dataset.parallaxBound !== 'true') {
			window.addEventListener('scroll', onScroll, { passive: true });
			bgLayer.dataset.parallaxBound = 'true';
		}
		updateParallax();
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDynamicBackground, { once: true });
	} else {
		initDynamicBackground();
	}

	document.addEventListener('astro:page-load', initDynamicBackground);
</script>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		font-family: Inter, system-ui, sans-serif;
		background: #020617;
		color: #0f172a;
	}

	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
		isolation: isolate;
	}

	.bg-image-layer,
	.bg-dim-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.bg-image-layer {
		z-index: 0;
		overflow: hidden;
		--bg-shift: 0px;
		--bg-scale: 1.12;
	}

	.bg-image-layer::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: var(--initial-bg-image, var(--default-bg-image, none));
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		transform: translate3d(0, 0, 0) scale(1.12);
		opacity: 1;
		transition: opacity 420ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.bg-image-layer.has-live-image::before {
		opacity: 0;
	}

	.bg-frame {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		opacity: 0;
		transform: translate3d(0, var(--bg-shift), 0) scale(var(--bg-scale));
		transition: transform 120ms linear, opacity 420ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform;
	}

	.bg-frame-a {
		background-image: var(--initial-bg-image, var(--default-bg-image, none));
		opacity: 1;
	}

	.bg-image-layer.is-b-active .bg-frame-a {
		opacity: 0;
	}

	.bg-image-layer.is-b-active .bg-frame-b {
		opacity: 1;
	}

	.bg-dim-overlay {
		z-index: 1;
		background: linear-gradient(to bottom, rgba(2, 6, 23, 0.52), rgba(2, 6, 23, 0.68));
	}


	.hero-panel {
		display: flex;
		justify-content: center;
		padding: 80px 24px 0;
		position: relative;
		z-index: 2;
	}

	.video-player {
		width: 100%;
		max-width: 1120px;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
		position: relative;
		isolation: isolate;
		border-radius: 8px;
		box-shadow:
			0 0 56px rgba(2, 6, 23, 0.38),
			0 28px 72px rgba(2, 6, 23, 0.5);
	}

	.video-player::after {
		content: '';
		position: absolute;
		inset: -18px;
		border-radius: 14px;
		pointer-events: none;
		z-index: -1;
		box-shadow: 0 0 48px rgba(2, 6, 23, 0.34);
	}

	.video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.video-grid {
		display: flex;
		justify-content: center;
		margin-top: 50px;
		padding: 0 24px 48px;
		position: relative;
		z-index: 2;
	}

	.grid-card {
		width: min(1120px, 100%);
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 24px;
	}

	.grid-video-item {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.grid-video-player {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #000;
		position: relative;
		isolation: isolate;
		border-radius: 8px;
		box-shadow:
			0 0 44px rgba(2, 6, 23, 0.34),
			0 22px 56px rgba(2, 6, 23, 0.42);
	}

	.grid-video-player::after {
		content: '';
		position: absolute;
		inset: -14px;
		border-radius: 12px;
		pointer-events: none;
		z-index: -1;
		box-shadow: 0 0 34px rgba(2, 6, 23, 0.3);
	}

	.grid-video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.video-description {
		display: flex;
		flex-direction: column;
		gap: 4px;
		margin: 0;
	}

	.video-description-title {
		display: block;
		font-size: 1.05rem;
		font-weight: 700;
		color: #f8fafc;
	}

	.video-description-copy {
		color: #cbd5e1;
		font-size: 0.95rem;
		font-weight: 300;
		line-height: 1.6;
	}

	@media (max-width: 860px) {
		.grid-card {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 580px) {
		.hero-panel {
			padding: 12px 14px 0;
		}

		.video-grid {
			margin-top: 28px;
			padding: 0 14px 28px;
		}

		.grid-card {
			gap: 20px;
		}

		.grid-video-item {
			gap: 12px;
		}

		.video-description-title {
			font-size: 1rem;
		}

		.video-description-copy {
			font-size: 0.92rem;
			line-height: 1.5;
		}
	}
</style>

