---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProjectsBackground from '../../components/ProjectsBackground.astro';
import featureImage from '../../assets/teapot/snapshot.jpg';
---

<Layout>
	<Header />
	<main class="project-detail-page projects-background-surface">
		<ProjectsBackground />
		<section class="project-detail-card">
			<a class="back-link" href="/projects">Back to projects</a>
			<div class="project-detail-media">
				<img src={featureImage.src} alt="Bunny Teapot artwork" />
			</div>
			<div class="project-detail-copy">
				<p class="eyebrow">Project Detail</p>
				<h1>Bunny Teapot</h1>
				<p>
					Use this page for behind-the-scenes material, iteration snapshots, or written notes that support the
					image card on the projects grid.
				</p>
				<p>
					The page is intentionally reachable only through its card link or direct URL, so it stays outside the
					main navigation tabs.
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.project-detail-page {
		padding: 32px 24px 56px;
		position: relative;
		z-index: 2;
	}

	.project-detail-card {
		width: min(1080px, 100%);
		margin: 0 auto;
		display: grid;
		gap: 28px;
		padding: 28px;
		background: rgba(255, 255, 255, 0.76);
		border: 1px solid rgba(15, 23, 42, 0.1);
		box-shadow: 0 24px 56px rgba(148, 163, 184, 0.18);
	}

	.back-link {
		width: fit-content;
		color: #0f172a;
		text-decoration: none;
		font-family: 'Quicksand', sans-serif;
		font-weight: 700;
	}

	.project-detail-media {
		overflow: hidden;
		border-radius: 12px;
		background: #dbe7f5;
	}

	.project-detail-media img {
		width: 100%;
		height: auto;
		display: block;
		object-fit: cover;
	}

	.project-detail-copy {
		display: grid;
		gap: 16px;
		color: #1e293b;
	}

	.eyebrow {
		margin: 0;
		font-family: 'Quicksand', sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #475569;
	}

	h1,
	p {
		margin: 0;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 3.25rem);
	}

	p {
		font-size: 1rem;
		line-height: 1.7;
	}

	@media (max-width: 580px) {
		.project-detail-page {
			padding: 20px 14px 36px;
		}

		.project-detail-card {
			padding: 18px;
			gap: 20px;
		}
	}
</style>
