---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const posterModules = import.meta.glob('../assets/p*.*', { eager: true, import: 'default' });
const posters = Object.entries(posterModules)
	.map(([path, mod]) => {
		const match = path.match(/[\\/]p(\d+)\./i);
		const src =
			typeof mod === 'string'
				? mod
				: typeof (mod as { src?: unknown }).src === 'string'
					? ((mod as { src: string }).src)
					: typeof (mod as { default?: unknown }).default === 'string'
						? ((mod as { default: string }).default)
						: typeof ((mod as { default?: { src?: unknown } }).default?.src) === 'string'
							? ((mod as { default: { src: string } }).default.src)
							: '';
		return {
			sortOrder: match ? Number(match[1]) : Number.MAX_SAFE_INTEGER,
			title: `Poster ${match ? match[1] : ''}`.trim(),
			src,
		};
	})
	.filter((poster) => poster.src)
		.sort((a, b) => b.sortOrder - a.sortOrder);

const loopPosters = [...posters, ...posters];
const posterStep = 300;
const loopDistance = posters.length * posterStep;
const loopDuration = Math.max(12, posters.length * 3.5);
const backgroundImages = posters.map((poster) => poster.src);
---

<Layout>
	<Header />
	<main class="landing-page">
		<script is:inline>
			try {
				const initialBg =
					sessionStorage.getItem('portfolio-painted-bg-image') ??
					sessionStorage.getItem('portfolio-bg-image');
				if (initialBg) {
					document.documentElement.style.setProperty('--initial-bg-image', `url("${initialBg}")`);
				}
			} catch {
				// Ignore storage access errors.
			}
		</script>
		<div
			class="bg-image-layer"
			aria-hidden="true"
			style={`--default-bg-image: url('${backgroundImages[0] ?? ''}')`}
		>
			<div class="bg-frame bg-frame-a"></div>
			<div class="bg-frame bg-frame-b"></div>
		</div>
		<div class="bg-dim-overlay" aria-hidden="true"></div>

		<section class="hero-panel" id="home">
			<div class="hero-card">
				<div class="video-player">
					<iframe
						id="home-vimeo-player"
						src="https://player.vimeo.com/video/925707755?api=1&player_id=home-vimeo-player"
						title="VFX demo reel"
						frameborder="0"
						allow="autoplay; fullscreen; picture-in-picture"
						allowfullscreen
					></iframe>
				</div>
			</div>
		</section>

		<section
			class="poster-carousel"
			aria-label="Movie posters carousel"
			style={`--loop-distance: ${loopDistance}px; --carousel-duration: ${loopDuration}s;`}
		>
			<div class="carousel-track">
				{loopPosters.map((poster) => (
					<article class="poster-card">
						<img class="poster-image" src={poster.src} alt="Movie poster" loading="lazy" />
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>

<script src="https://player.vimeo.com/api/player.js"></script>
<script define:vars={{ backgroundImages }}>
	const initDynamicBackground = () => {
		const bgLayer = document.querySelector('.bg-image-layer');
		const bgFrameA = bgLayer?.querySelector('.bg-frame-a');
		const bgFrameB = bgLayer?.querySelector('.bg-frame-b');
		const bgRuntimeState = /** @type {Window & { __homeReloadBgHandled?: boolean }} */ (window);
		const bgStorageKey = 'portfolio-bg-image';
		const paintedBgKey = 'portfolio-painted-bg-image';
		const refreshHomeBgKey = 'portfolio-refresh-home-bg';

		if (
			!(bgLayer instanceof HTMLElement) ||
			!(bgFrameA instanceof HTMLElement) ||
			!(bgFrameB instanceof HTMLElement) ||
			!Array.isArray(backgroundImages) ||
			backgroundImages.length === 0
		) {
			return;
		}

		const navEntry = performance.getEntriesByType('navigation')[0];
		const navType = navEntry && typeof navEntry === 'object' && 'type' in navEntry ? navEntry.type : '';
		const shouldRefreshFromHomeClick =
			window.location.pathname === '/' && sessionStorage.getItem(refreshHomeBgKey) === '1';
		const shouldRefreshFromHomeReload =
			window.location.pathname === '/' && navType === 'reload' && bgRuntimeState.__homeReloadBgHandled !== true;

		if (shouldRefreshFromHomeClick || shouldRefreshFromHomeReload) {
			sessionStorage.removeItem(bgStorageKey);
			sessionStorage.removeItem(refreshHomeBgKey);
			if (shouldRefreshFromHomeReload) {
				bgRuntimeState.__homeReloadBgHandled = true;
			}
		}

		let sharedBgImage = sessionStorage.getItem(bgStorageKey);
		if (!sharedBgImage) {
			const randomIndex = Math.floor(Math.random() * backgroundImages.length);
			sharedBgImage = backgroundImages[randomIndex];
			sessionStorage.setItem(bgStorageKey, sharedBgImage);
		}

		const paintedBgImage = sessionStorage.getItem(paintedBgKey);
		const shouldUseFallback = !bgLayer.classList.contains('has-live-image');
		const activeIsB = bgLayer.classList.contains('is-b-active');
		const activeFrame = activeIsB ? bgFrameB : bgFrameA;
		const inactiveFrame = activeIsB ? bgFrameA : bgFrameB;
		let activeBgUrl = activeFrame.dataset.bgUrl ?? '';

		const setFrameImage = (frame, imageUrl) => {
			frame.style.backgroundImage = `url("${imageUrl}")`;
			frame.dataset.bgUrl = imageUrl;
		};

		const revealBackground = () => {
			if (shouldUseFallback) {
				bgLayer.classList.add('has-live-image');
			}
			document.documentElement.style.setProperty('--initial-bg-image', `url("${sharedBgImage}")`);
			sessionStorage.setItem(paintedBgKey, sharedBgImage);
		};

		const preloadImage = (imageUrl, onReady) => {
			const preload = new Image();
			preload.src = imageUrl;
			if (typeof preload.decode === 'function') {
				preload.decode().catch(() => undefined).finally(onReady);
				return;
			}
			preload.onload = onReady;
			preload.onerror = onReady;
		};

		if (!activeBgUrl) {
			const seedImage = paintedBgImage || sharedBgImage;
			setFrameImage(activeFrame, seedImage);
			activeBgUrl = seedImage;
		}

		if (activeBgUrl !== sharedBgImage) {
			preloadImage(sharedBgImage, () => {
				setFrameImage(inactiveFrame, sharedBgImage);
				bgLayer.classList.toggle('is-b-active', !activeIsB);
				revealBackground();
			});
		} else {
			setFrameImage(activeFrame, sharedBgImage);
			revealBackground();
		}

		const maxShift = 26;
		const scale = 1.12;
		let ticking = false;

		const updateParallax = () => {
			const shift = Math.max(-maxShift, Math.min(maxShift, window.scrollY * 0.12));
			bgLayer.style.setProperty('--bg-shift', `${shift.toFixed(2)}px`);
			bgLayer.style.setProperty('--bg-scale', `${scale}`);
			ticking = false;
		};

		const onScroll = () => {
			if (ticking) {
				return;
			}

			ticking = true;
			window.requestAnimationFrame(updateParallax);
		};

		if (bgLayer.dataset.parallaxBound !== 'true') {
			window.addEventListener('scroll', onScroll, { passive: true });
			bgLayer.dataset.parallaxBound = 'true';
		}
		updateParallax();
	};

	const setVideoPlayingState = (isPlaying) => {
		const carousel = document.querySelector('.poster-carousel');
		const carouselTrack = document.querySelector('.carousel-track');

		if (!(carousel instanceof HTMLElement) || !(carouselTrack instanceof HTMLElement)) {
			return;
		}

		carousel.classList.toggle('is-video-playing', isPlaying);
		carouselTrack.style.animationPlayState = isPlaying ? 'paused' : 'running';
	};

	const initVideoAwareCarousel = () => {
		const iframe = document.getElementById('home-vimeo-player');

		if (!(iframe instanceof HTMLIFrameElement) || iframe.dataset.videoSyncBound === 'true') {
			return;
		}

		const vimeoApi = window.Vimeo;
		if (!vimeoApi || typeof vimeoApi.Player !== 'function') {
			return;
		}

		const player = new vimeoApi.Player(iframe);
		player.on('play', () => {
			setVideoPlayingState(true);
		});
		player.on('pause', () => {
			setVideoPlayingState(false);
		});
		player.on('ended', () => {
			setVideoPlayingState(false);
		});
		iframe.dataset.videoSyncBound = 'true';
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => {
			initDynamicBackground();
			initVideoAwareCarousel();
		}, { once: true });
	} else {
		initDynamicBackground();
		initVideoAwareCarousel();
	}

	document.addEventListener('astro:page-load', initDynamicBackground);
	document.addEventListener('astro:page-load', initVideoAwareCarousel);
</script>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		font-family: Inter, system-ui, sans-serif;
		background: #020617;
		color: #0f172a;
	}

	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
		isolation: isolate;
		overflow-x: clip;
	}

	.bg-image-layer,
	.bg-dim-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.bg-image-layer {
		z-index: 0;
		overflow: hidden;
		--bg-shift: 0px;
		--bg-scale: 1.12;
	}

	.bg-image-layer::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: var(--initial-bg-image, var(--default-bg-image, none));
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		transform: translate3d(0, 0, 0) scale(1.12);
		opacity: 1;
		transition: opacity 420ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.bg-image-layer.has-live-image::before {
		opacity: 0;
	}

	.bg-frame {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		opacity: 0;
		transform: translate3d(0, var(--bg-shift), 0) scale(var(--bg-scale));
		transition: transform 120ms linear, opacity 420ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform;
	}

	.bg-frame-a {
		background-image: var(--initial-bg-image, var(--default-bg-image, none));
		opacity: 1;
	}

	.bg-image-layer.is-b-active .bg-frame-a {
		opacity: 0;
	}

	.bg-image-layer.is-b-active .bg-frame-b {
		opacity: 1;
	}

	.bg-dim-overlay {
		z-index: 1;
		background: linear-gradient(to bottom, rgba(2, 6, 23, 0.52), rgba(2, 6, 23, 0.68));
	}

	.hero-panel,
	.poster-carousel {
		position: relative;
		z-index: 2;
	}

	.hero-panel {
		flex: 0.5;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 80px 24px 48px;
	}

	.hero-card {
		width: min(1120px, 100%);
		padding: 24px;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 32px;
		background: #ffffff;
		isolation: isolate;
        box-shadow: 0 0 48px rgba(2, 6, 23, 0.34);
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		gap: 32px;
	}


	.video-player {
		width: 100%;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
		border-radius: 8px;
	}

	.poster-carousel {
		width: 100%;
		margin: 36px 0 0;
		padding: 0 24px;
		box-sizing: border-box;
		overflow: hidden;
		filter: brightness(0.8);
		transition: filter 180ms ease;
	}

	.poster-carousel.is-video-playing {
		filter: brightness(0.4);
	}

	.carousel-track {
		display: flex;
		width: auto;
		animation: carousel var(--carousel-duration, s) linear infinite;
		gap: 20px;
		transform: translateX(0);
	}

	.poster-card {
		flex: 0 0 280px;
		width: 280px;
		height: 380px;
		position: relative;
		border-radius: 0;
		overflow: hidden;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.poster-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@keyframes carousel {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(calc(-1 * var(--loop-distance, 1180px)));
		}
	}

	.video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	@media (max-width: 580px) {
		.hero-panel {
			padding: 12px 14px 24px;
		}

		.hero-card {
			padding: 14px;
			border-radius: 20px;
			gap: 20px;
		}

		.video-player {
			max-height: none;
			border-radius: 10px;
		}

		.poster-carousel {
			margin-top: 20px;
			padding: 0 14px;
		}

		.carousel-track {
			gap: 14px;
		}

		.poster-card {
			flex-basis: 180px;
			width: 180px;
			height: 250px;
		}
	}
</style>
