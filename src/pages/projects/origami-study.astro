---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProjectsBackground from '../../components/ProjectsBackground.astro';
---

<Layout>
	<Header />
	<main class="project-detail-page projects-background-surface">
		<ProjectsBackground />
		<section class="hero-panel">
			<div class="hero-media">
				<iframe
					src="https://player.vimeo.com/video/200915611"
					title="Origami Study"
					frameborder="0"
					allow="autoplay; fullscreen; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>
		</section>
		<section class="project-detail-card">
			<a class="back-link" href="/projects">Back to projects</a>
			<div class="project-detail-copy">
				<p class="eyebrow">Project Detail</p>
				<h1>Origami Study</h1>
				<p>
					This page uses the same hero-panel framing as the main projects page and now loads the Origami Study Vimeo
					piece directly in the lead panel.
				</p>
				<p>
					You can build this section out with process notes, reference material, or additional images while keeping
					the shared header and background treatment consistent with the rest of the projects area.
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.project-detail-page {
		padding: 0 24px 56px;
		position: relative;
		z-index: 2;
	}

	.hero-panel {
		display: flex;
		justify-content: center;
		padding: 80px 0 0;
		position: relative;
		z-index: 2;
	}

	.hero-media {
		width: 100%;
		max-width: 1120px;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
		position: relative;
		isolation: isolate;
		border-radius: 8px;
		box-shadow:
			0 0 56px rgba(2, 6, 23, 0.38),
			0 28px 72px rgba(2, 6, 23, 0.5);
	}

	.hero-media::after {
		content: '';
		position: absolute;
		inset: -18px;
		border-radius: 14px;
		pointer-events: none;
		z-index: -1;
		box-shadow: 0 0 48px rgba(2, 6, 23, 0.34);
	}

	.hero-media iframe {
		width: 100%;
		height: 100%;
		display: block;
		border: 0;
	}

	.project-detail-card {
		width: min(1080px, 100%);
		margin: 50px auto 0;
		display: grid;
		gap: 28px;
		padding: 28px;
		background: rgba(255, 255, 255, 0.76);
		border: 1px solid rgba(15, 23, 42, 0.1);
		box-shadow: 0 24px 56px rgba(148, 163, 184, 0.18);
	}

	.back-link {
		width: fit-content;
		color: #0f172a;
		text-decoration: none;
		font-family: 'Quicksand', sans-serif;
		font-weight: 700;
	}

	.project-detail-copy {
		display: grid;
		gap: 16px;
		color: #1e293b;
	}

	.eyebrow {
		margin: 0;
		font-family: 'Quicksand', sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #475569;
	}

	h1,
	p {
		margin: 0;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 3.25rem);
	}

	p {
		font-size: 1rem;
		line-height: 1.7;
	}

	@media (max-width: 580px) {
		.project-detail-page {
			padding: 0 14px 36px;
		}

		.hero-panel {
			padding-top: 12px;
		}

		.project-detail-card {
			margin-top: 28px;
			padding: 18px;
			gap: 20px;
		}
	}
</style>