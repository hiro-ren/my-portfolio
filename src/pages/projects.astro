---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProjectsBackground from '../components/ProjectsBackground.astro';
import origamiStudySnapshot from '../assets/origami/snapshot.jpg';
import bunnyTeapotSnapshot from '../assets/teapot/snapshot.jpg';
---

<Layout>
	<Header />
	<main class="landing-page projects-background-surface">
		<ProjectsBackground />

		<section class="hero-panel" id="projects-video">
			<div class="video-player">
				<iframe
					src="https://www.youtube.com/embed/gB90me0aqSY"
					title="YouTube demo reel"
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>
		</section>

		<section class="video-grid" id="projects-grid">
			<div class="grid-card">
				<div class="grid-video-item">
					<div class="grid-video-player">
						<iframe
							src="https://player.vimeo.com/video/685058136?api=1&player_id=projects-grid-player"
							title="2021 Spring Festival Gala Feature"
							frameborder="0"
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-description">
						<div class="video-description-title">2021 Spring Festival Gala Feature</div>
						<div class="video-description-copy">Responsible for env and props modeling, textures, and set dressing.</div>
					</div>
				</div>
				<div class="grid-video-item">
					<div class="grid-video-player">
						<iframe
							src="https://player.vimeo.com/video/251238799"
							title="VFX demo reel"
							frameborder="0"
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-description">
						<div class="video-description-title">Pixar Undergraduate Program</div>
						<div class="video-description-copy">Responsible for modelling, particle effects, additional lighting.</div>
					</div>
				</div>
				<div class="grid-video-item">
					<div class="grid-video-player">
						<iframe
							src="https://player.vimeo.com/video/197258267"
							title="VFX demo reel"
							frameborder="0"
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-description">
						<div class="video-description-title">BIRDCAGE - Short Film</div>
						<div class="video-description-copy">Responsible for Lighting, Shading, and compositing.
Vincent Cappelluti animation film ▷ http://www.vincentcapp.com/.</div>
					</div>
				</div>
				<div class="grid-video-item">
					<div class="grid-video-player">
						<iframe
							src="https://player.vimeo.com/video/685056706"
							title="Pixar Tailoring Workflow Study"
							frameborder="0"
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="video-description">
						<div class="video-description-title">Pixar Tailoring Workflow Study</div>
						<div class="video-description-copy">A study of Pixar's tailoring workflow during PUP program.</div>
					</div>
				</div>
				<div class="grid-video-item">
					<a class="grid-video-player grid-image-link" href="/projects/origami-study" aria-label="Open origami study project page">
						<img src={origamiStudySnapshot.src} alt="Origami study project preview" loading="lazy" />
					</a>
					<div class="video-description">
						<div class="video-description-title">Origami Study</div>
						<div class="video-description-copy">Image-based project card. Select it to open a dedicated page with more context and artwork.</div>
					</div>
				</div>
				<div class="grid-video-item">
					<a class="grid-video-player grid-image-link" href="/projects/bunny-teapot" aria-label="Open Bunny Teapot project page">
						<img src={bunnyTeapotSnapshot.src} alt="Bunny Teapot project preview" loading="lazy" />
					</a>
					<div class="video-description">
						<div class="video-description-title">Bunny Teapot - Renderman .RIB</div>
						<div class="video-description-copy">This project was done by Pixar's RenderMan RIB coding.</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}


	.hero-panel {
		display: flex;
		justify-content: center;
		padding: 80px 24px 0;
		position: relative;
		z-index: 2;
	}

	.video-player {
		width: 100%;
		max-width: 1120px;
		aspect-ratio: 16 / 9;
		max-height: 80vh;
		overflow: hidden;
		background: #000;
		position: relative;
		isolation: isolate;
		border-radius: 8px;
		box-shadow:
			0 0 56px rgba(2, 6, 23, 0.38),
			0 28px 72px rgba(2, 6, 23, 0.5);
	}

	.video-player::after {
		content: '';
		position: absolute;
		inset: -18px;
		border-radius: 14px;
		pointer-events: none;
		z-index: -1;
		box-shadow: 0 0 48px rgba(2, 6, 23, 0.34);
	}

	.video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.video-grid {
		display: flex;
		justify-content: center;
		margin-top: 50px;
		padding: 0 24px 48px;
		position: relative;
		z-index: 2;
	}

	.grid-card {
		width: min(1120px, 100%);
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 24px;
	}

	.grid-video-item {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.grid-video-player {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #000;
		position: relative;
		isolation: isolate;
		border-radius: 8px;
		box-shadow:
			0 0 44px rgba(2, 6, 23, 0.34),
			0 22px 56px rgba(2, 6, 23, 0.42);
	}

	.grid-video-player::after {
		content: '';
		position: absolute;
		inset: -14px;
		border-radius: 12px;
		pointer-events: none;
		z-index: -1;
		box-shadow: 0 0 34px rgba(2, 6, 23, 0.3);
	}

	.grid-video-player iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.grid-image-link {
		text-decoration: none;
		transition: transform 0.24s ease, box-shadow 0.24s ease;
	}

	.grid-image-link img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.grid-image-link:focus-visible {
		outline: 3px solid rgba(248, 250, 252, 0.9);
		outline-offset: 4px;
	}

	@media (hover: hover) and (pointer: fine) {
		.grid-image-link:hover {
			transform: translateY(-4px);
			box-shadow:
				0 0 44px rgba(2, 6, 23, 0.42),
				0 28px 64px rgba(2, 6, 23, 0.48);
		}
	}

	.video-description {
		display: flex;
		flex-direction: column;
		gap: 4px;
		margin: 0;
	}

	.video-description-title {
		display: block;
		font-size: 1.05rem;
		font-weight: 700;
		color: #f8fafc;
	}

	.video-description-copy {
		color: #cbd5e1;
		font-size: 0.95rem;
		font-weight: 300;
		line-height: 1.6;
	}

	@media (max-width: 860px) {
		.grid-card {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 580px) {
		.hero-panel {
			padding: 12px 14px 0;
		}

		.video-grid {
			margin-top: 28px;
			padding: 0 14px 28px;
		}

		.grid-card {
			gap: 20px;
		}

		.grid-video-item {
			gap: 12px;
		}

		.video-description-title {
			font-size: 1rem;
		}

		.video-description-copy {
			font-size: 0.92rem;
			line-height: 1.5;
		}
	}
</style>

