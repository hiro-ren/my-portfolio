---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import resumeImage from '../assets/HiroRen_Resume.jpeg';

const posterModules = import.meta.glob('../assets/p*.*', { eager: true, import: 'default' });
const posters = Object.entries(posterModules)
	.map(([path, mod]) => {
		const match = path.match(/[\\/]p(\d+)\./i);
		const src =
			typeof mod === 'string'
				? mod
				: typeof (mod as { src?: unknown }).src === 'string'
					? ((mod as { src: string }).src)
					: typeof (mod as { default?: unknown }).default === 'string'
						? ((mod as { default: string }).default)
						: typeof ((mod as { default?: { src?: unknown } }).default?.src) === 'string'
							? ((mod as { default: { src: string } }).default.src)
							: '';
		return {
			src,
		};
	})
	.filter((poster) => poster.src);

const backgroundImages = posters.map((poster) => poster.src);
---

<Layout>
	<Header />
	<main class="landing-page">
		<script is:inline>
			try {
				const initialBg =
					sessionStorage.getItem('portfolio-painted-bg-image') ??
					sessionStorage.getItem('portfolio-bg-image');
				if (initialBg) {
					document.documentElement.style.setProperty('--initial-bg-image', `url("${initialBg}")`);
				}
			} catch {
				// Ignore storage access errors.
			}
		</script>
		<div
			class="bg-image-layer"
			aria-hidden="true"
			style={`--default-bg-image: url('${backgroundImages[0] ?? ''}')`}
		>
			<div class="bg-frame bg-frame-a"></div>
			<div class="bg-frame bg-frame-b"></div>
		</div>
		<div class="bg-dim-overlay" aria-hidden="true"></div>

		<section class="page-shell">
			<div class="resume-layout">
				<div class="resume-grid">
					<section class="resume-section-card resume-section-download">
						<div class="resume-download-column">
							<a class="resume-download-button" href={resumeImage.src} download="HiroRen_Resume.jpeg">Download Resume</a>
						</div>
					</section>

					<section class="resume-section-card resume-section-social">
						<div class="resume-social-column" aria-label="Social links">
							<a href="https://www.linkedin.com/in/hiro-ren-470970115/" target="_blank" rel="noreferrer" aria-label="LinkedIn">
								<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
									<path d="M6.94 8.5v9H4v-9h2.94zM7.1 5.89c0 .92-.7 1.66-1.66 1.66-.95 0-1.64-.74-1.64-1.66 0-.94.7-1.68 1.66-1.68.96 0 1.62.74 1.64 1.68zM20 12.34v5.16h-2.93v-4.83c0-1.21-.44-2.03-1.52-2.03-.83 0-1.32.56-1.54 1.1-.08.2-.1.48-.1.76v5h-2.94s.04-8.11 0-9h2.94v1.27c.39-.6 1.1-1.46 2.69-1.46 1.97 0 3.4 1.28 3.4 4.03z"/>
								</svg>
							</a>
							<a href="https://www.tiktok.com/@weekend.catcrochet?lang=en" target="_blank" rel="noreferrer" aria-label="TikTok">
								<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
									<path d="M15.5 3c.35 1.98 1.52 3.1 3.5 3.35v2.56c-1.31.12-2.42-.2-3.5-.8v5.06c0 2.55-1.56 4.57-4.32 5.04-2.94.5-5.68-1.4-6.13-4.34-.45-2.94 1.42-5.62 4.3-6.08.43-.07.84-.1 1.24-.06v2.7c-.3-.03-.6-.02-.9.03-1.4.2-2.37 1.48-2.17 2.88.2 1.4 1.5 2.38 2.9 2.16 1.13-.17 1.99-1.14 1.99-2.34V3h3.09z"/>
								</svg>
							</a>
						</div>
					</section>

					<section class="resume-section-card">
						<div class="resume-contact-column">
							<a href="tel:+11234567890">T: +1 604 841 1105</a>
							<a href="mailto:yourname@email.com">E: ruiruiali@gmail.com</a>
						</div>
					</section>
				</div>

				<div class="resume-image-placeholder">
					<img src={resumeImage.src} alt="Hiro Ren resume" loading="lazy" decoding="async" />
				</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script define:vars={{ backgroundImages }}>
	const initDynamicBackground = () => {
		const bgLayer = document.querySelector('.bg-image-layer');
		const bgFrameA = bgLayer?.querySelector('.bg-frame-a');
		const bgFrameB = bgLayer?.querySelector('.bg-frame-b');
		const bgStorageKey = 'portfolio-bg-image';
		const paintedBgKey = 'portfolio-painted-bg-image';

		if (
			!(bgLayer instanceof HTMLElement) ||
			!(bgFrameA instanceof HTMLElement) ||
			!(bgFrameB instanceof HTMLElement) ||
			!Array.isArray(backgroundImages) ||
			backgroundImages.length === 0
		) {
			return;
		}

		const navEntry = performance.getEntriesByType('navigation')[0];
		const navType = navEntry && typeof navEntry === 'object' && 'type' in navEntry ? navEntry.type : '';

		let sharedBgImage = sessionStorage.getItem(bgStorageKey);
		if (!sharedBgImage) {
			const randomIndex = Math.floor(Math.random() * backgroundImages.length);
			sharedBgImage = backgroundImages[randomIndex];
			sessionStorage.setItem(bgStorageKey, sharedBgImage);
		}

		const paintedBgImage = sessionStorage.getItem(paintedBgKey);
		const shouldUseFallback = !bgLayer.classList.contains('has-live-image');
		const activeIsB = bgLayer.classList.contains('is-b-active');
		const activeFrame = activeIsB ? bgFrameB : bgFrameA;
		const inactiveFrame = activeIsB ? bgFrameA : bgFrameB;
		let activeBgUrl = activeFrame.dataset.bgUrl ?? '';

		const setFrameImage = (frame, imageUrl) => {
			frame.style.backgroundImage = `url("${imageUrl}")`;
			frame.dataset.bgUrl = imageUrl;
		};

		const revealBackground = () => {
			if (shouldUseFallback) {
				bgLayer.classList.add('has-live-image');
			}
			document.documentElement.style.setProperty('--initial-bg-image', `url("${sharedBgImage}")`);
			sessionStorage.setItem(paintedBgKey, sharedBgImage);
		};

		const preloadImage = (imageUrl, onReady) => {
			const preload = new Image();
			preload.src = imageUrl;
			if (typeof preload.decode === 'function') {
				preload.decode().catch(() => undefined).finally(onReady);
				return;
			}
			preload.onload = onReady;
			preload.onerror = onReady;
		};

		if (!activeBgUrl) {
			const seedImage = paintedBgImage || sharedBgImage;
			setFrameImage(activeFrame, seedImage);
			activeBgUrl = seedImage;
		}

		if (activeBgUrl !== sharedBgImage) {
			preloadImage(sharedBgImage, () => {
				setFrameImage(inactiveFrame, sharedBgImage);
				bgLayer.classList.toggle('is-b-active', !activeIsB);
				revealBackground();
			});
		} else {
			setFrameImage(activeFrame, sharedBgImage);
			revealBackground();
		}

		const maxShift = 26;
		const scale = 1.12;
		let ticking = false;

		const getPullRefreshOffset = () => {
			const visualViewportOffset = window.visualViewport?.offsetTop ?? 0;
			if (visualViewportOffset > 0) {
				return visualViewportOffset;
			}

			const documentTop = document.documentElement.getBoundingClientRect().top;
			return documentTop > 0 ? documentTop : 0;
		};

		const updateParallax = () => {
			const shift = Math.max(-maxShift, Math.min(maxShift + 44, window.scrollY * 0.12 + getPullRefreshOffset()));
			bgLayer.style.setProperty('--bg-shift', `${shift.toFixed(2)}px`);
			bgLayer.style.setProperty('--bg-scale', `${scale}`);
			ticking = false;
		};

		const onScroll = () => {
			if (ticking) {
				return;
			}

			ticking = true;
			window.requestAnimationFrame(updateParallax);
		};

		if (bgLayer.dataset.parallaxBound !== 'true') {
			window.addEventListener('scroll', onScroll, { passive: true });
			window.visualViewport?.addEventListener('scroll', onScroll, { passive: true });
			window.visualViewport?.addEventListener('resize', onScroll, { passive: true });
			bgLayer.dataset.parallaxBound = 'true';
		}
		updateParallax();
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDynamicBackground, { once: true });
	} else {
		initDynamicBackground();
	}

	document.addEventListener('astro:page-load', initDynamicBackground);
</script>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		font-family: Inter, system-ui, sans-serif;
		background: #020617;
		color: #0f172a;
	}

	.landing-page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
		isolation: isolate;
	}

	.bg-image-layer,
	.bg-dim-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.bg-image-layer {
		z-index: 0;
		overflow: hidden;
		--bg-shift: 0px;
		--bg-scale: 1.12;
	}

	.bg-image-layer::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: var(--initial-bg-image, var(--default-bg-image, none));
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		transform: translate3d(0, 0, 0) scale(1.12);
		opacity: 1;
		transition: opacity 420ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.bg-image-layer.has-live-image::before {
		opacity: 0;
	}

	.bg-frame {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: blur(5px) saturate(1.05) brightness(0.9);
		opacity: 0;
		transform: translate3d(0, var(--bg-shift), 0) scale(var(--bg-scale));
		transition: transform 120ms linear, opacity 420ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform;
	}

	.bg-frame-a {
		background-image: var(--initial-bg-image, var(--default-bg-image, none));
		opacity: 1;
	}

	.bg-image-layer.is-b-active .bg-frame-a {
		opacity: 0;
	}

	.bg-image-layer.is-b-active .bg-frame-b {
		opacity: 1;
	}

	.bg-dim-overlay {
		z-index: 1;
		background: linear-gradient(to bottom, rgba(2, 6, 23, 0.52), rgba(2, 6, 23, 0.68));
	}

	.page-shell {
		position: relative;
		z-index: 2;
		min-height: 100vh;
		padding: 44px 24px;
		color: #ffffff;
		font-family: 'Quicksand', sans-serif;
	}

	.resume-layout {
		display: grid;
		grid-template-columns: minmax(300px, 0px) minmax(0, 1fr);
		align-items: start;
		max-width: 1120px;
		margin: 0 auto;
	}

	.resume-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 14px;
		align-items: start;
	}

	.resume-image-placeholder {
		width: 100%;
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 14px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.04);
	}

	.resume-image-placeholder img {
		display: block;
		width: 100%;
		height: auto;
	}

	.resume-section-card {
		padding: 5px;
		display: flex;
		flex-direction: column;
		gap: 14px;
		align-items: flex-start;
		text-align: left;
	}

	.resume-section-download {
		margin-bottom: 100px;
	}

	.resume-section-social {
		margin-top: -5px;
	}

	.resume-contact-column {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.resume-contact-column a {
		text-decoration: none;
		color: #ffffff;
		font-size: 0.98rem;
		font-weight: 500;
	}

	.resume-social-column {
		display: flex;
		gap: 14px;
		align-items: center;
		justify-content: flex-start;
	}

	.resume-social-column a {
		width: 42px;
		height: 42px;
		border-radius: 999px;
		display: grid;
		place-items: center;
		background: rgba(255, 255, 255, 0.14);
		border: 1px solid rgba(255, 255, 255, 0.42);
		color: #ffffff;
	}

	.resume-social-column svg {
		width: 20px;
		height: 20px;
		fill: currentColor;
	}

	.resume-download-column {
		display: flex;
		justify-content: flex-start;
		width: 100%;
	}

	.resume-download-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 42px;
		padding: 0 18px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.16);
		border: 1px solid rgba(255, 255, 255, 0.45);
		color: #ffffff;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.92rem;
	}

	@media (max-width: 860px) {
		.resume-layout {
			grid-template-columns: 1fr;
			gap: 20px;
		}

		.resume-grid {
			grid-template-columns: 1fr;
			gap: 18px;
		}

		.resume-social-column,
		.resume-download-column {
			justify-content: flex-start;
		}
	}

	@media (max-width: 580px) {
		.page-shell {
			padding: 20px 14px 28px;
		}

		.resume-layout {
			gap: 16px;
		}

		.resume-section-download {
			margin-bottom: 20px;
		}

		.resume-section-social {
			margin-top: 0;
		}

		.resume-download-button {
			width: 100%;
			min-height: 46px;
			padding: 0 14px;
		}

		.resume-contact-column a {
			font-size: 0.94rem;
			line-height: 1.5;
		}
	}
</style>
